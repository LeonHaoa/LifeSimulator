{
  "name": "life-simulator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "node scripts/free-port.mjs 3001 && next dev --hostname 127.0.0.1 --port 3001",
    "dev:stable": "node scripts/free-port.mjs 3001 && LLM_TIMEOUT_MS=20000 WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev --hostname 127.0.0.1 --port 3001",
    "dev:fresh": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\" && npm run dev:stable",
    "dev:turbo": "node scripts/free-port.mjs 3001 && next dev --turbo --hostname 127.0.0.1 --port 3001",
    "build": "next build",
    "start": "next start",
    "start:local": "node scripts/free-port.mjs 3001 && LLM_TIMEOUT_MS=20000 next start --hostname 127.0.0.1 --port 3001",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --keep-vars"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.0",
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.81.1"
  }
}
